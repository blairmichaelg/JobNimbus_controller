# ============================================================
# Wickham Roofing AI Orchestrator — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# === JobNimbus CRM ===
JOBNIMBUS_API_KEY=your_jobnimbus_bearer_token_here
JOBNIMBUS_BASE_URL=https://app.jobnimbus.com/api1
JOBNIMBUS_ACTOR_EMAIL=scott@wickhamroofing.com

# === Webhook Security ===
# Shared secret for the x-api-key header validation on inbound webhooks.
# JobNimbus does NOT sign webhooks with HMAC — this is our custom auth layer.
WEBHOOK_SECRET=your_shared_x_api_key_secret_here

# === Redis (Render Internal Key-Value Store) ===
# Use the internal connection URL from your Render dashboard.
# Format: redis://<host>:<port>
REDIS_URL=redis://localhost:6379

# === Google Gemini AI ===
GEMINI_API_KEY=your_gemini_api_key_here

# === Application Settings ===
APP_ENV=development
LOG_LEVEL=DEBUG

# The CRM status name used to quarantine test jobs.
# Only webhooks matching this status will be processed.
QUARANTINE_STATUS=API TEST LAB

# When true, all outbound CRM mutations (PUT/POST) are logged but NOT executed.
# MUST be true during initial development and testing.
DRY_RUN=true
